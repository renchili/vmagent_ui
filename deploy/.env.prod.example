# image
IMAGE_REPO=registry.example.com/renchili/vmagent-ui
IMAGE_TAG=latest

# network
APP_PORT=3099

# mysql
MYSQL_DSN=vmagent_ui:REPLACE_ME_STRONG_PASSWORD@tcp(mysql.internal:3306)/vmagent_ui?parseTime=true&multiStatements=true

# app
DEFAULT_CONFIG_PATH=config/sample-vmagent.yml
DEFAULT_AUTHOR=jenkins
CONTAINER_CONFIG_DIR=/app/config

# vmagent apply
VMAGENT_CONFIG_PATH=/etc/vmagent/config.yml

# 建议一开始先用 noop，确认 UI / DB / 发布链路没问题后再切 reload
APPLY_MODE=noop

# 如果使用 HTTP reload，填真实地址
VMAGENT_RELOAD_URL=http://vmagent.internal:8429/-/reload

# 如果不用 PID / restart command，可以留空
VMAGENT_PID=
VMAGENT_RESTART_CMD=
